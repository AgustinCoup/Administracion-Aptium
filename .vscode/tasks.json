{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven: clean compile",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "compile"
            ],
            "isBackground": false,
            "problemMatcher": [
                "$javac"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "maven: test",
            "type": "shell",
            "command": "mvn",
            "args": [
                "test"
            ],
            "isBackground": false,
            "problemMatcher": [
                "$javac"
            ]
        }
    ]
}
