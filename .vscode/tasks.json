{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven: clean compile",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "compile"
            ],
            "isBackground": false,
            "problemMatcher": [
                "$javac"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "maven: test",
            "type": "shell",
            "command": "mvn",
            "args": [
                "test"
            ],
            "isBackground": false,
            "problemMatcher": [
                "$javac"
            ]
        },
        {
            "label": "maven: package",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package"
            ],
            "isBackground": false,
            "problemMatcher": [
                "$javac"
            ]
        }
    ]
}
